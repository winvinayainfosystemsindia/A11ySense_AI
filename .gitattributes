# Handle line endings automatically for files detected as text 
# and leave binary files alone
* text=auto

# Explicitly declare text files to always use LF on checkout
*.py text eol=lf
*.md text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.txt text eol=lf
*.json text eol=lf

# Denote all files that are truly binary and should not be modified
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
